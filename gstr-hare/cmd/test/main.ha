// Comprehensive test program for gstr Hare implementation

use fmt;
use gstr;

export fn main() void = {
	fmt::println("gstr-hare comprehensive test suite")!;
	fmt::println("===================================")!;
	fmt::println("")!;
	
	let passed: size = 0;
	let failed: size = 0;
	
	// =========================================================================
	// Basic Length Tests
	// =========================================================================
	fmt::println("=== Basic Length (gstrlen) ===")!;
	
	if (test_len("", 0)) passed += 1 else failed += 1;
	if (test_len("a", 1)) passed += 1 else failed += 1;
	if (test_len("hello", 5)) passed += 1 else failed += 1;
	if (test_len("Hello World", 11)) passed += 1 else failed += 1;
	
	// =========================================================================
	// Latin Extended (2 bytes, width 1)
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Latin Extended ===")!;
	
	if (test_len("cafГ©", 4)) passed += 1 else failed += 1;  // precomposed Г©
	if (test_len("naГҜve", 5)) passed += 1 else failed += 1;
	if (test_len("rГ©sumГ©", 6)) passed += 1 else failed += 1;
	
	// Decomposed vs Precomposed
	// Г© precomposed (U+00E9) = 1 grapheme
	if (test_len("\xC3\xA9", 1)) passed += 1 else failed += 1;
	// e + combining acute (U+0065 U+0301) = 1 grapheme (combines)
	if (test_len("e\xCC\x81", 1)) passed += 1 else failed += 1;
	
	// =========================================================================
	// CJK Characters (3 bytes, width 2 each)
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== CJK Characters ===")!;
	
	if (test_len("дёӯ", 1)) passed += 1 else failed += 1;
	if (test_len("дёӯж–Ү", 2)) passed += 1 else failed += 1;
	if (test_len("ж—Ҙжң¬иӘһ", 3)) passed += 1 else failed += 1;
	if (test_len("дё–з•Ң", 2)) passed += 1 else failed += 1;
	
	if (test_width("дёӯ", 2)) passed += 1 else failed += 1;
	if (test_width("дёӯж–Ү", 4)) passed += 1 else failed += 1;
	if (test_width("ж—Ҙжң¬иӘһ", 6)) passed += 1 else failed += 1;
	
	// =========================================================================
	// Hangul
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Hangul ===")!;
	
	// Precomposed Hangul syllables
	if (test_len("н•ңкёҖ", 2)) passed += 1 else failed += 1;
	if (test_len("к°Җ", 1)) passed += 1 else failed += 1;  // precomposed GA
	if (test_width("н•ңкёҖ", 4)) passed += 1 else failed += 1;
	
	// Hangul Jamo (should cluster: L + V = 1 grapheme)
	// г„ұ (U+1100) + г…Ҹ (U+1161) = к°Җ
	if (test_len("\xE1\x84\x80\xE1\x85\xA1", 1)) passed += 1 else failed += 1;
	
	// L + V + T = 1 grapheme: г„ұ + г…Ҹ + г„ҙ = к°„
	if (test_len("\xE1\x84\x80\xE1\x85\xA1\xE1\x86\xAB", 1)) passed += 1 else failed += 1;
	
	// =========================================================================
	// Simple Emoji (4 bytes, width 2)
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Simple Emoji ===")!;
	
	if (test_len("рҹҳҖ", 1)) passed += 1 else failed += 1;
	if (test_len("рҹҺү", 1)) passed += 1 else failed += 1;
	if (test_len("рҹ‘Ӣ", 1)) passed += 1 else failed += 1;
	if (test_width("рҹҳҖ", 2)) passed += 1 else failed += 1;
	
	// Heart with variation selector (2 codepoints, 1 grapheme)
	// вқӨпёҸ = вқӨ (U+2764) + VS16 (U+FE0F)
	if (test_len("\xE2\x9D\xA4\xEF\xB8\x8F", 1)) passed += 1 else failed += 1;
	
	// =========================================================================
	// Flags (Regional Indicators)
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Flags ===")!;
	
	// рҹҮЁрҹҮҰ Canada = Regional Indicator C + A
	if (test_len("рҹҮЁрҹҮҰ", 1)) passed += 1 else failed += 1;
	if (test_len("рҹҮәрҹҮё", 1)) passed += 1 else failed += 1;
	if (test_len("рҹҮҜрҹҮө", 1)) passed += 1 else failed += 1;
	if (test_len("рҹҮ¬рҹҮ§", 1)) passed += 1 else failed += 1;
	if (test_len("рҹҮ«рҹҮ·", 1)) passed += 1 else failed += 1;
	
	// Multiple flags
	if (test_len("рҹҮЁрҹҮҰрҹҮәрҹҮё", 2)) passed += 1 else failed += 1;
	if (test_len("рҹҮЁрҹҮҰрҹҮәрҹҮёрҹҮҜрҹҮө", 3)) passed += 1 else failed += 1;
	
	if (test_width("рҹҮЁрҹҮҰ", 2)) passed += 1 else failed += 1;
	
	// =========================================================================
	// Skin Tone Modifiers
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Skin Tone Modifiers ===")!;
	
	// рҹ‘ӢрҹҸ» light skin
	if (test_len("рҹ‘ӢрҹҸ»", 1)) passed += 1 else failed += 1;
	// рҹ‘ӢрҹҸҪ medium skin
	if (test_len("рҹ‘ӢрҹҸҪ", 1)) passed += 1 else failed += 1;
	// рҹ‘ӢрҹҸҝ dark skin
	if (test_len("рҹ‘ӢрҹҸҝ", 1)) passed += 1 else failed += 1;
	
	// All five skin tones on same base
	if (test_len("рҹ‘ӢрҹҸ»рҹ‘ӢрҹҸјрҹ‘ӢрҹҸҪрҹ‘ӢрҹҸҫрҹ‘ӢрҹҸҝ", 5)) passed += 1 else failed += 1;
	
	// =========================================================================
	// ZWJ Sequences
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== ZWJ Sequences ===")!;
	
	// рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§ family (man + ZWJ + woman + ZWJ + girl)
	if (test_len("рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§", 1)) passed += 1 else failed += 1;
	
	// рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§вҖҚрҹ‘Ұ family of four
	if (test_len("рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§вҖҚрҹ‘Ұ", 1)) passed += 1 else failed += 1;
	
	// рҹ‘ЁвҖҚрҹ’» man technologist
	if (test_len("рҹ‘ЁвҖҚрҹ’»", 1)) passed += 1 else failed += 1;
	
	// рҹ‘©вҖҚрҹ”¬ woman scientist
	if (test_len("рҹ‘©вҖҚрҹ”¬", 1)) passed += 1 else failed += 1;
	
	// рҹҸіпёҸвҖҚрҹҢҲ rainbow flag
	if (test_len("рҹҸіпёҸвҖҚрҹҢҲ", 1)) passed += 1 else failed += 1;
	
	// рҹҸіпёҸвҖҚвҡ§пёҸ transgender flag
	if (test_len("рҹҸіпёҸвҖҚвҡ§пёҸ", 1)) passed += 1 else failed += 1;
	
	// ZWJ sequence with skin tone: рҹ‘ЁрҹҸҪвҖҚрҹ’» man technologist medium skin
	if (test_len("рҹ‘ЁрҹҸҪвҖҚрҹ’»", 1)) passed += 1 else failed += 1;
	
	if (test_width("рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§", 2)) passed += 1 else failed += 1;
	
	// =========================================================================
	// Combining Marks
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Combining Marks ===")!;
	
	// a + combining acute (U+0301)
	if (test_len("a\xCC\x81", 1)) passed += 1 else failed += 1;
	
	// o + combining diaeresis (U+0308)
	if (test_len("o\xCC\x88", 1)) passed += 1 else failed += 1;
	
	// s + dot below (U+0323) + dot above (U+0307) = б№©
	if (test_len("s\xCC\xA3\xCC\x87", 1)) passed += 1 else failed += 1;
	
	// Multiple combining marks
	if (test_len("a\xCC\x81\xCC\x82\xCC\x83", 1)) passed += 1 else failed += 1;  // a + acute + circumflex + tilde
	
	// =========================================================================
	// Zero-Width Characters
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Zero-Width Characters ===")!;
	
	// Zero-width space (U+200B)
	if (test_len("\xE2\x80\x8B", 1)) passed += 1 else failed += 1;
	if (test_width("\xE2\x80\x8B", 0)) passed += 1 else failed += 1;
	
	// Word joiner (U+2060)
	if (test_len("\xE2\x81\xA0", 1)) passed += 1 else failed += 1;
	if (test_width("\xE2\x81\xA0", 0)) passed += 1 else failed += 1;
	
	// ZWJ alone (U+200D)
	if (test_len("\xE2\x80\x8D", 1)) passed += 1 else failed += 1;
	if (test_width("\xE2\x80\x8D", 0)) passed += 1 else failed += 1;
	
	// ZWNJ alone (U+200C)
	if (test_len("\xE2\x80\x8C", 1)) passed += 1 else failed += 1;
	if (test_width("\xE2\x80\x8C", 0)) passed += 1 else failed += 1;
	
	// =========================================================================
	// Keycap Sequences
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Keycap Sequences ===")!;
	
	// 1пёҸвғЈ = 1 + VS16 + combining enclosing keycap
	if (test_len("1пёҸвғЈ", 1)) passed += 1 else failed += 1;
	if (test_len("2пёҸвғЈ", 1)) passed += 1 else failed += 1;
	if (test_len("#пёҸвғЈ", 1)) passed += 1 else failed += 1;
	if (test_len("*пёҸвғЈ", 1)) passed += 1 else failed += 1;
	
	// =========================================================================
	// Mixed Strings
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Mixed Strings ===")!;
	
	// HiрҹҮЁрҹҮҰдёӯрҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§!
	if (test_len("HiрҹҮЁрҹҮҰдёӯрҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§!", 6)) passed += 1 else failed += 1;
	// Width: H(1) i(1) рҹҮЁрҹҮҰ(2) дёӯ(2) рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§(2) !(1) = 9
	if (test_width("HiрҹҮЁрҹҮҰдёӯрҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§!", 9)) passed += 1 else failed += 1;
	
	// AдёӯрҹҮҜрҹҮөрҹ‘ЁвҖҚрҹ’»Г©
	if (test_len("AдёӯрҹҮҜрҹҮөрҹ‘ЁвҖҚрҹ’»Г©", 5)) passed += 1 else failed += 1;
	// Width: A(1) дёӯ(2) рҹҮҜрҹҮө(2) рҹ‘ЁвҖҚрҹ’»(2) Г©(1) = 8
	if (test_width("AдёӯрҹҮҜрҹҮөрҹ‘ЁвҖҚрҹ’»Г©", 8)) passed += 1 else failed += 1;
	
	// =========================================================================
	// Edge Cases
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Edge Cases ===")!;
	
	// Fullwidth space (U+3000) - width 2
	if (test_len("\xE3\x80\x80", 1)) passed += 1 else failed += 1;
	if (test_width("\xE3\x80\x80", 2)) passed += 1 else failed += 1;
	
	// Only combining marks (orphaned) - should still count as graphemes
	if (test_len("\xCC\x81", 1)) passed += 1 else failed += 1;  // lone combining acute
	
	// Very long combining sequence
	if (test_len("a\xCC\x81\xCC\x82\xCC\x83\xCC\x84\xCC\x85", 1)) passed += 1 else failed += 1;
	
	// =========================================================================
	// gstrat Tests
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Character Access (gstrat) ===")!;
	
	if (test_at("hello", 0, "h")) passed += 1 else failed += 1;
	if (test_at("hello", 4, "o")) passed += 1 else failed += 1;
	if (test_at("cafГ©", 3, "Г©")) passed += 1 else failed += 1;
	if (test_at("дё–з•Ң", 0, "дё–")) passed += 1 else failed += 1;
	if (test_at("дё–з•Ң", 1, "з•Ң")) passed += 1 else failed += 1;
	
	// Emoji access
	if (test_at("рҹ‘ӢрҹҸҪ", 0, "рҹ‘ӢрҹҸҪ")) passed += 1 else failed += 1;
	if (test_at("рҹҮЁрҹҮҰрҹҮәрҹҮё", 0, "рҹҮЁрҹҮҰ")) passed += 1 else failed += 1;
	if (test_at("рҹҮЁрҹҮҰрҹҮәрҹҮё", 1, "рҹҮәрҹҮё")) passed += 1 else failed += 1;
	
	// Family
	if (test_at("Aрҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§B", 0, "A")) passed += 1 else failed += 1;
	if (test_at("Aрҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§B", 1, "рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§")) passed += 1 else failed += 1;
	if (test_at("Aрҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§B", 2, "B")) passed += 1 else failed += 1;
	
	// Out of bounds
	if (test_at_void("hello", 10)) passed += 1 else failed += 1;
	if (test_at_void("", 0)) passed += 1 else failed += 1;
	
	// =========================================================================
	// gstrcmp Tests
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Comparison (gstrcmp) ===")!;
	
	if (test_cmp("abc", "abc", 0)) passed += 1 else failed += 1;
	if (test_cmp("abc", "abd", -1)) passed += 1 else failed += 1;
	if (test_cmp("abd", "abc", 1)) passed += 1 else failed += 1;
	if (test_cmp("ab", "abc", -1)) passed += 1 else failed += 1;
	if (test_cmp("abc", "ab", 1)) passed += 1 else failed += 1;
	if (test_cmp("", "", 0)) passed += 1 else failed += 1;
	if (test_cmp("a", "", 1)) passed += 1 else failed += 1;
	if (test_cmp("", "a", -1)) passed += 1 else failed += 1;
	
	// Unicode comparison
	if (test_cmp("дё–з•Ң", "дё–з•Ң", 0)) passed += 1 else failed += 1;
	if (test_cmp("рҹ‘Ӣ", "рҹ‘Ӣ", 0)) passed += 1 else failed += 1;
	if (test_cmp("рҹҮЁрҹҮҰ", "рҹҮәрҹҮё", -1)) passed += 1 else failed += 1;
	
	// =========================================================================
	// Iterator Tests
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Iterator ===")!;
	
	if (test_iter("abc", ["a", "b", "c"])) passed += 1 else failed += 1;
	if (test_iter("дё–з•Ң", ["дё–", "з•Ң"])) passed += 1 else failed += 1;
	if (test_iter("рҹ‘ӢрҹҸҪ", ["рҹ‘ӢрҹҸҪ"])) passed += 1 else failed += 1;
	if (test_iter("рҹҮЁрҹҮҰрҹҮәрҹҮё", ["рҹҮЁрҹҮҰ", "рҹҮәрҹҮё"])) passed += 1 else failed += 1;
	if (test_iter("рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§", ["рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§"])) passed += 1 else failed += 1;
	if (test_iter("", [])) passed += 1 else failed += 1;
	
	// Mixed
	if (test_iter("Hiдёӯ!", ["H", "i", "дёӯ", "!"])) passed += 1 else failed += 1;
	
	// =========================================================================
	// Substring Tests
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Substrings ===")!;
	
	if (test_startswith("hello world", "hello", true)) passed += 1 else failed += 1;
	if (test_startswith("hello world", "world", false)) passed += 1 else failed += 1;
	if (test_startswith("рҹҮЁрҹҮҰCanada", "рҹҮЁрҹҮҰ", true)) passed += 1 else failed += 1;
	if (test_startswith("", "", true)) passed += 1 else failed += 1;
	if (test_startswith("a", "", true)) passed += 1 else failed += 1;
	
	if (test_endswith("hello world", "world", true)) passed += 1 else failed += 1;
	if (test_endswith("hello world", "hello", false)) passed += 1 else failed += 1;
	if (test_endswith("CanadaрҹҮЁрҹҮҰ", "рҹҮЁрҹҮҰ", true)) passed += 1 else failed += 1;
	
	// =========================================================================
	// Search Tests
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Search (gstrchr) ===")!;
	
	if (test_chr("hello", "l", 2)) passed += 1 else failed += 1;
	if (test_chr("hello", "x", void)) passed += 1 else failed += 1;
	if (test_chr("дё–з•Ңhello", "h", 2)) passed += 1 else failed += 1;
	if (test_chr("рҹҮЁрҹҮҰрҹҮәрҹҮёрҹҮҜрҹҮө", "рҹҮәрҹҮё", 1)) passed += 1 else failed += 1;
	if (test_chr("рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§family", "f", 1)) passed += 1 else failed += 1;
	if (test_chr("", "a", void)) passed += 1 else failed += 1;
	
	// =========================================================================
	// Width regression: EAW split (ExtPict symbols should be width 1, not 2)
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== Width Regression (EAW Split) ===")!;
	
	// These are Extended_Pictographic but NOT East_Asian_Width W/F
	// They should be width 1, not width 2
	if (test_width("вҷ ", 1)) passed += 1 else failed += 1;
	if (test_width("вҷЈ", 1)) passed += 1 else failed += 1;
	if (test_width("вҷҘ", 1)) passed += 1 else failed += 1;
	if (test_width("вҷҰ", 1)) passed += 1 else failed += 1;
	if (test_width("вҳ…", 1)) passed += 1 else failed += 1;
	// These ARE East_Asian_Width W/F вҖ” should be width 2
	if (test_width("рҹҳҖ", 2)) passed += 1 else failed += 1;
	if (test_width("ж—Ҙ", 2)) passed += 1 else failed += 1;
	
	// =========================================================================
	// ZWJ regression: ExtPict should join, non-ExtPict should not
	// =========================================================================
	fmt::println("")!;
	fmt::println("=== ZWJ Regression (ExtPict Split) ===")!;
	
	// вҷ  (U+2660) IS Extended_Pictographic вҖ” ZWJ should join
	if (test_len("вҷ \u200Dвҷ ", 1)) passed += 1 else failed += 1;
	// дёӯ (U+4E2D) is NOT Extended_Pictographic вҖ” ZWJ should not join
	if (test_len("дёӯ\u200Dдёӯ", 2)) passed += 1 else failed += 1;
	// вҳ… (U+2605) is NOT Extended_Pictographic вҖ” ZWJ should not join
	if (test_len("вҳ…\u200Dвҳ…", 2)) passed += 1 else failed += 1;
	
	// =========================================================================
	// Summary
	// =========================================================================
	fmt::println("")!;
	fmt::println("===================================")!;
	fmt::printfln("Passed: {}", passed)!;
	fmt::printfln("Failed: {}", failed)!;
	
	if (failed > 0) {
		fmt::println("SOME TESTS FAILED")!;
	} else {
		fmt::println("ALL TESTS PASSED")!;
	};
};

fn test_len(s: str, expected: size) bool = {
	const result = gstr::gstrlen(s);
	if (result == expected) {
		fmt::printfln("  PASS: gstrlen({}) = {}", repr(s), result)!;
		return true;
	};
	fmt::printfln("  FAIL: gstrlen({}) = {}, expected {}", repr(s), result, expected)!;
	return false;
};

fn test_width(s: str, expected: size) bool = {
	const result = gstr::gstrwidth(s);
	if (result == expected) {
		fmt::printfln("  PASS: gstrwidth({}) = {}", repr(s), result)!;
		return true;
	};
	fmt::printfln("  FAIL: gstrwidth({}) = {}, expected {}", repr(s), result, expected)!;
	return false;
};

fn test_at(s: str, n: size, expected: str) bool = {
	match (gstr::gstrat(s, n)) {
	case let result: str =>
		if (result == expected) {
			fmt::printfln("  PASS: gstrat({}, {}) = {}", repr(s), n, repr(result))!;
			return true;
		};
		fmt::printfln("  FAIL: gstrat({}, {}) = {}, expected {}", 
		              repr(s), n, repr(result), repr(expected))!;
		return false;
	case void =>
		fmt::printfln("  FAIL: gstrat({}, {}) = void, expected {}", 
		              repr(s), n, repr(expected))!;
		return false;
	};
};

fn test_at_void(s: str, n: size) bool = {
	match (gstr::gstrat(s, n)) {
	case str =>
		fmt::printfln("  FAIL: gstrat({}, {}) should be void", repr(s), n)!;
		return false;
	case void =>
		fmt::printfln("  PASS: gstrat({}, {}) = void", repr(s), n)!;
		return true;
	};
};

fn test_cmp(a: str, b: str, expected: i8) bool = {
	const result = gstr::gstrcmp(a, b);
	const normalized: i8 = if (result < 0) -1 else if (result > 0) 1 else 0;
	if (normalized == expected) {
		fmt::printfln("  PASS: gstrcmp({}, {}) = {}", repr(a), repr(b), normalized)!;
		return true;
	};
	fmt::printfln("  FAIL: gstrcmp({}, {}) = {}, expected {}", 
	              repr(a), repr(b), normalized, expected)!;
	return false;
};

fn test_startswith(s: str, prefix: str, expected: bool) bool = {
	const result = gstr::gstrstartswith(s, prefix);
	if (result == expected) {
		fmt::printfln("  PASS: gstrstartswith({}, {}) = {}", repr(s), repr(prefix), result)!;
		return true;
	};
	fmt::printfln("  FAIL: gstrstartswith({}, {}) = {}, expected {}", 
	              repr(s), repr(prefix), result, expected)!;
	return false;
};

fn test_endswith(s: str, suffix: str, expected: bool) bool = {
	const result = gstr::gstrendswith(s, suffix);
	if (result == expected) {
		fmt::printfln("  PASS: gstrendswith({}, {}) = {}", repr(s), repr(suffix), result)!;
		return true;
	};
	fmt::printfln("  FAIL: gstrendswith({}, {}) = {}, expected {}", 
	              repr(s), repr(suffix), result, expected)!;
	return false;
};

fn test_chr(s: str, g: str, expected: (size | void)) bool = {
	const result = gstr::gstrchr(s, g);
	match (expected) {
	case let e: size =>
		match (result) {
		case let r: size =>
			if (r == e) {
				fmt::printfln("  PASS: gstrchr({}, {}) = {}", repr(s), repr(g), r)!;
				return true;
			};
			fmt::printfln("  FAIL: gstrchr({}, {}) = {}, expected {}", 
			              repr(s), repr(g), r, e)!;
			return false;
		case void =>
			fmt::printfln("  FAIL: gstrchr({}, {}) = void, expected {}", 
			              repr(s), repr(g), e)!;
			return false;
		};
	case void =>
		match (result) {
		case size =>
			fmt::printfln("  FAIL: gstrchr({}, {}) found, expected void", repr(s), repr(g))!;
			return false;
		case void =>
			fmt::printfln("  PASS: gstrchr({}, {}) = void", repr(s), repr(g))!;
			return true;
		};
	};
};

fn test_iter(s: str, expected: []str) bool = {
	let it = gstr::iter(s);
	let idx: size = 0;
	
	for (true) {
		const g = gstr::next(&it);
		match (g) {
		case void =>
			if (idx == len(expected)) {
				fmt::printfln("  PASS: iter({}) produced {} graphemes", repr(s), idx)!;
				return true;
			};
			fmt::printfln("  FAIL: iter({}) ended at {}, expected {}", 
			              repr(s), idx, len(expected))!;
			return false;
		case let gs: str =>
			if (idx >= len(expected)) {
				fmt::printfln("  FAIL: iter({}) extra grapheme at {}", repr(s), idx)!;
				return false;
			};
			if (gs != expected[idx]) {
				fmt::printfln("  FAIL: iter({})[{}] = {}, expected {}", 
				              repr(s), idx, repr(gs), repr(expected[idx]))!;
				return false;
			};
			idx += 1;
		};
	};
};

// Helper to create a display representation of a string
fn repr(s: str) str = {
	// For now, just return the string with quotes
	// A proper repr would escape non-printable characters
	return s;
};
